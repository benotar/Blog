# Normalize all text files to LF on commit
* text=auto eol=lf

# C# / .NET
*.cs       text eol=lf
*.csproj   text eol=lf
*.sln      text eol=lf
*.props    text eol=lf
*.targets  text eol=lf

# Config / data
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.xml      text eol=lf
*.config   text eol=lf
*.md       text eol=lf
*.txt      text eol=lf
*.sh       text eol=lf

# Docker
Dockerfile        text eol=lf
*.dockerignore    text eol=lf

# PowerShell stays CRLF (Windows-native)
*.ps1      text eol=crlf
*.psm1     text eol=crlf

# Binary — never touch
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.dll      binary
*.exe      binary
*.pdb      binary
